<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Legacy storage write for DownloadManager on API < 29; scoped storage above. -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- See/launch external browsers for the "open external links in browser" feature (API 30+). -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
    </queries>

    <application
        android:name=".RutaApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/Theme.Ruta"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode|density|smallestScreenSize"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Ruta.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!--
              Open links to the wrapped social sites from other apps. Hosts are listed explicitly
              (rather than a host-less browser filter) so each domain shows up under Android's
              "Open by default → supported web addresses" screen, where the user can let ruta
              handle them. autoVerify stays off: these are third-party domains we can't host an
              assetlinks.json on, so verification can't succeed — the user opts in manually.
            -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:scheme="http" />
                <data android:host="x.com" />
                <data android:host="*.x.com" />
                <data android:host="twitter.com" />
                <data android:host="*.twitter.com" />
                <data android:host="instagram.com" />
                <data android:host="*.instagram.com" />
                <data android:host="facebook.com" />
                <data android:host="*.facebook.com" />
                <data android:host="fb.com" />
                <data android:host="*.fb.com" />
                <data android:host="tiktok.com" />
                <data android:host="*.tiktok.com" />
                <data android:host="reddit.com" />
                <data android:host="*.reddit.com" />
                <data android:host="redd.it" />
                <data android:host="bsky.app" />
                <data android:host="*.bsky.app" />
                <data android:host="threads.net" />
                <data android:host="*.threads.net" />
                <data android:host="threads.com" />
                <data android:host="*.threads.com" />
                <data android:host="linkedin.com" />
                <data android:host="*.linkedin.com" />
                <data android:host="tumblr.com" />
                <data android:host="*.tumblr.com" />
                <data android:host="mastodon.social" />
                <data android:host="*.mastodon.social" />
            </intent-filter>
        </activity>

        <!-- Hilt provides the WorkManager factory; disable default initializer. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>
</manifest>
