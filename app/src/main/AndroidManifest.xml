<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- No POST_NOTIFICATIONS: the only notification (download complete) is posted by the
         system's DownloadManager under its own identity, so the app never needs to ask. -->
    <!-- Legacy storage write for DownloadManager on API < 29; scoped storage above. -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- See/launch external browsers for the "open external links in browser" feature (API 30+). -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
    </queries>

    <application
        android:name=".RutaApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/Theme.Ruta"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode|density|smallestScreenSize"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Ruta.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          One alias per wrapped site carries that site's link (VIEW) filter. Hosts are listed
          explicitly (rather than a single host-less browser filter) so each domain shows up under
          Android's "Open by default → supported web addresses" screen. Each alias can be toggled
          at runtime via PackageManager (see LinkHandling) so the user can choose, per site, whether
          ruta handles its links — disabling an alias removes its domain from that screen.
          autoVerify stays off: these are third-party domains we can't host an assetlinks.json on,
          so verification can't succeed — the user opts in manually.
        -->
        <activity-alias android:name=".LinkAlias_x" android:targetActivity=".MainActivity"
            android:exported="true" android:label="X">
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:scheme="http" />
                <data android:host="x.com" />
                <data android:host="*.x.com" />
                <data android:host="twitter.com" />
                <data android:host="*.twitter.com" />
            </intent-filter>
        </activity-alias>
        <activity-alias android:name=".LinkAlias_instagram" android:targetActivity=".MainActivity"
            android:exported="true" android:label="Instagram">
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:scheme="http" />
                <data android:host="instagram.com" />
                <data android:host="*.instagram.com" />
            </intent-filter>
        </activity-alias>
        <activity-alias android:name=".LinkAlias_facebook" android:targetActivity=".MainActivity"
            android:exported="true" android:label="Facebook">
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:scheme="http" />
                <data android:host="facebook.com" />
                <data android:host="*.facebook.com" />
                <data android:host="fb.com" />
                <data android:host="*.fb.com" />
            </intent-filter>
        </activity-alias>
        <activity-alias android:name=".LinkAlias_tiktok" android:targetActivity=".MainActivity"
            android:exported="true" android:label="TikTok">
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:scheme="http" />
                <data android:host="tiktok.com" />
                <data android:host="*.tiktok.com" />
            </intent-filter>
        </activity-alias>
        <activity-alias android:name=".LinkAlias_reddit" android:targetActivity=".MainActivity"
            android:exported="true" android:label="Reddit">
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:scheme="http" />
                <data android:host="reddit.com" />
                <data android:host="*.reddit.com" />
                <data android:host="redd.it" />
            </intent-filter>
        </activity-alias>
        <activity-alias android:name=".LinkAlias_bluesky" android:targetActivity=".MainActivity"
            android:exported="true" android:label="Bluesky">
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:scheme="http" />
                <data android:host="bsky.app" />
                <data android:host="*.bsky.app" />
            </intent-filter>
        </activity-alias>
        <activity-alias android:name=".LinkAlias_threads" android:targetActivity=".MainActivity"
            android:exported="true" android:label="Threads">
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:scheme="http" />
                <data android:host="threads.net" />
                <data android:host="*.threads.net" />
                <data android:host="threads.com" />
                <data android:host="*.threads.com" />
            </intent-filter>
        </activity-alias>
        <activity-alias android:name=".LinkAlias_linkedin" android:targetActivity=".MainActivity"
            android:exported="true" android:label="LinkedIn">
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:scheme="http" />
                <data android:host="linkedin.com" />
                <data android:host="*.linkedin.com" />
            </intent-filter>
        </activity-alias>
        <activity-alias android:name=".LinkAlias_tumblr" android:targetActivity=".MainActivity"
            android:exported="true" android:label="Tumblr">
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:scheme="http" />
                <data android:host="tumblr.com" />
                <data android:host="*.tumblr.com" />
            </intent-filter>
        </activity-alias>
        <activity-alias android:name=".LinkAlias_mastodon" android:targetActivity=".MainActivity"
            android:exported="true" android:label="Mastodon">
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:scheme="http" />
                <data android:host="mastodon.social" />
                <data android:host="*.mastodon.social" />
            </intent-filter>
        </activity-alias>

        <!-- Hilt provides the WorkManager factory; disable default initializer. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>
</manifest>
